{
  "name": "nexachat",
  "version": "0.1.0",
  "description": "Local-first multi-model AI conversation hub.",
  "main": "dist-electron/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "dev:electron": "concurrently -k \"npm:dev\" \"wait-on http://127.0.0.1:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "typecheck": "tsc --noEmit",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "build": "npm run typecheck && npm run build:renderer && npm run build:main",
    "start": "npm run build && electron .",
    "test": "vitest run",
    "test:ui-smoke": "playwright test tests/ui-smoke.spec.ts",
    "test:electron-smoke": "node scripts/electron-smoke.mjs",
    "verify": "npm run typecheck && npm run test && npm run build"
  },
  "keywords": [
    "electron",
    "ai",
    "chat",
    "local-first"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^39.2.7",
    "lucide-react": "^0.562.0",
    "vite": "^7.2.7",
    "wait-on": "^9.0.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.10.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^27.3.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15",
    "react": "^19.2.1",
    "react-dom": "^19.2.1"
  }
}
